    {
      "path": "registry/new-york/blocks/logo-cloud/logo-cloud-section-v1/page.tsx",
      "content": "import LogoCloudSectionV1 from \"./logo-cloud-section-v1\";\r\n\r\nexport default function Page() {\r\n  return <LogoCloudSectionV1 />;\r\n}\r\n",
